# Токен бота этого стенда (@BotFather)
TELEGRAM_KEY=

# S3 для медиа (опционально; без него — фолбэк на хранилище Telegram).
# Yandex Object Storage: endpoint storage.yandexcloud.net, регион ru-central1,
# публичное чтение объектов в бакете должно быть «Для всех»
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_PUBLIC_BASE=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# S3_TRAMPOLINE=1 — только если хостинг недоступен серверам Telegram (Selectel)

# AI-помощник (опционально).
# Вариант 1 — локальный демон Ollama:
OLLAMA_URL=http://localhost:11434
# Вариант 2 — облако ollama.com напрямую (демон не нужен):
#   OLLAMA_URL=https://ollama.com
#   OLLAMA_API_KEY=<ключ с ollama.com/settings/keys>
OLLAMA_API_KEY=
AI_MODEL=gemma4:cloud
