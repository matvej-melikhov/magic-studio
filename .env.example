# Токен бота этого стенда (@BotFather)
TELEGRAM_KEY=

# S3 для медиа (опционально; без него — фолбэк на хранилище Telegram)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_PUBLIC_BASE=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# AI-помощник (опционально).
# Вариант 1 — локальный демон Ollama:
OLLAMA_URL=http://localhost:11434
# Вариант 2 — облако ollama.com напрямую (демон не нужен):
#   OLLAMA_URL=https://ollama.com
#   OLLAMA_API_KEY=<ключ с ollama.com/settings/keys>
OLLAMA_API_KEY=
AI_MODEL=gemma4:cloud
