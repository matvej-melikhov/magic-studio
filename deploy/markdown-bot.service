[Unit]
Description=Студия постов — Telegram-бот (bot.py)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/markdown-bot
ExecStart=/opt/markdown-bot/venv/bin/python3 bot.py
Restart=always
RestartSec=5
User=markdown
Group=markdown

[Install]
WantedBy=multi-user.target
